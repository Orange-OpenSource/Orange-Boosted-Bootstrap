---
import Callout from '@components/shortcodes/Callout.astro'

/*
 * Outputs a callout for elements that are not yet available.
 */
interface Props {
  /**
   * @default 'component'
   */
  type?: string
}

const { type = 'component' } = Astro.props
---

<Callout
  type="warning"
  title={`This ${type} is not yet available.`}
  titleLevel={2}
  action="Check OUDS components statuses"
  actionHref="https://unified-design-system.orange.com/472794e18/p/73c701-components"
>
  Please check back soon.
</Callout>
